{
  "id": "annotation-demo",
  "name": "Visual Annotations - Physics Data Display",
  "description": "Comprehensive showcase of the visual annotation system. Learn to display real-time physics data: velocity vectors, speed labels, kinetic energy, momentum, position, and mass. These tools help visualize invisible physics quantities during simulations.",
  "version": "1.1",
  "objects": [
    {
      "id": "projectile",
      "type": "Sphere",
      "mass": 2,
      "radius": 0.5,
      "position": [-10, 8, 0],
      "velocity": [10, 6, 0],
      "color": "#FF4500",
      "friction": 0.3,
      "restitution": 0.6
    },
    {
      "id": "heavy_box",
      "type": "Box",
      "mass": 5,
      "dimensions": [1.8, 1.8, 1.8],
      "position": [8, 10, 0],
      "velocity": [0, 0, 0],
      "color": "#2ECC71",
      "friction": 0.4,
      "restitution": 0.5
    },
    {
      "id": "light_sphere",
      "type": "Sphere",
      "mass": 0.5,
      "radius": 0.4,
      "position": [0, 12, 3],
      "velocity": [3, 5, -2],
      "color": "#9B59B6",
      "friction": 0.2,
      "restitution": 0.8
    },
    {
      "id": "ground",
      "type": "Box",
      "mass": 0,
      "dimensions": [50, 0.3, 30],
      "position": [0, 0, 0],
      "color": "#34495E",
      "isStatic": true
    },
    {
      "id": "ramp",
      "type": "Box",
      "mass": 0,
      "dimensions": [12, 0.4, 6],
      "position": [-8, 2.5, 0],
      "rotation": [0, 0, -0.25],
      "color": "#7F8C8D",
      "isStatic": true,
      "friction": 0.3,
      "restitution": 0.5
    }
  ],
  "gravity": [0, -9.81, 0],
  "hasGround": true,
  "contactMaterial": {
    "friction": 0.4,
    "restitution": 0.6
  },
  "gravitationalPhysics": {
    "enabled": false
  },
  "simulationScale": "terrestrial",
  "visualAnnotations": [
    {
      "id": "proj-speed",
      "type": "text",
      "attachedToObjectId": "projectile",
      "contentType": "speed",
      "prefix": "Speed: ",
      "suffix": " m/s",
      "precision": 1,
      "offset": [0, 3.5, 0],
      "anchor": "top",
      "fontSize": 44,
      "color": "#ffffff",
      "backgroundColor": "rgba(255, 69, 0, 0.9)",
      "padding": 12,
      "borderRadius": 6,
      "visible": true,
      "minSpeed": 0.1,
      "smoothness": 0.15
    },
    {
      "id": "proj-velocity-vec",
      "type": "vector",
      "attachedToObjectId": "projectile",
      "vectorType": "velocity",
      "scale": 0.3,
      "color": "#00BFFF",
      "showMagnitude": true,
      "offset": [0, 0, 0],
      "anchor": "center",
      "visible": true,
      "shaftRadius": 0.05,
      "headLength": 0.25,
      "headRadius": 0.12,
      "smoothness": 0.15
    },
    {
      "id": "proj-position",
      "type": "text",
      "attachedToObjectId": "projectile",
      "contentType": "position",
      "prefix": "Pos: ",
      "precision": 1,
      "offset": [0, -3, 0],
      "anchor": "bottom",
      "fontSize": 36,
      "color": "#98FB98",
      "backgroundColor": "rgba(0, 0, 0, 0.7)",
      "padding": 10,
      "visible": true
    },
    {
      "id": "proj-ke",
      "type": "text",
      "attachedToObjectId": "projectile",
      "contentType": "kineticEnergy",
      "prefix": "KE: ",
      "suffix": " J",
      "precision": 1,
      "offset": [4, 0, 0],
      "anchor": "right",
      "fontSize": 36,
      "color": "#FF69B4",
      "backgroundColor": "rgba(0, 0, 0, 0.75)",
      "padding": 10,
      "visible": true
    },
    {
      "id": "proj-momentum",
      "type": "text",
      "attachedToObjectId": "projectile",
      "contentType": "momentum",
      "prefix": "p: ",
      "suffix": " kg·m/s",
      "precision": 1,
      "offset": [-4, 0, 0],
      "anchor": "left",
      "fontSize": 36,
      "color": "#FFD700",
      "backgroundColor": "rgba(0, 0, 0, 0.75)",
      "padding": 10,
      "visible": true
    },
    {
      "id": "box-speed",
      "type": "text",
      "attachedToObjectId": "heavy_box",
      "contentType": "speed",
      "prefix": "v: ",
      "suffix": " m/s",
      "precision": 2,
      "offset": [0, 3.5, 0],
      "anchor": "top",
      "fontSize": 40,
      "color": "#ffffff",
      "backgroundColor": "rgba(46, 204, 113, 0.9)",
      "padding": 12,
      "borderRadius": 5,
      "visible": true,
      "minSpeed": 0.05
    },
    {
      "id": "box-velocity-vec",
      "type": "vector",
      "attachedToObjectId": "heavy_box",
      "vectorType": "velocity",
      "scale": 0.4,
      "color": "#00FF7F",
      "showMagnitude": false,
      "offset": [0, 0, 0],
      "anchor": "center",
      "visible": true,
      "shaftRadius": 0.06,
      "headLength": 0.22,
      "headRadius": 0.1
    },
    {
      "id": "box-mass",
      "type": "text",
      "attachedToObjectId": "heavy_box",
      "contentType": "mass",
      "prefix": "Mass: ",
      "suffix": " kg",
      "precision": 1,
      "offset": [0, -3.5, 0],
      "anchor": "bottom",
      "fontSize": 36,
      "color": "#ffffff",
      "backgroundColor": "rgba(46, 204, 113, 0.7)",
      "padding": 10,
      "visible": true
    },
    {
      "id": "box-ke",
      "type": "text",
      "attachedToObjectId": "heavy_box",
      "contentType": "kineticEnergy",
      "prefix": "KE: ",
      "suffix": " J",
      "precision": 1,
      "offset": [3.5, 0, 0],
      "anchor": "right",
      "fontSize": 34,
      "color": "#F0E68C",
      "backgroundColor": "rgba(0, 0, 0, 0.7)",
      "padding": 10,
      "visible": true
    },
    {
      "id": "light-speed",
      "type": "text",
      "attachedToObjectId": "light_sphere",
      "contentType": "speed",
      "prefix": "Speed: ",
      "suffix": " m/s",
      "precision": 1,
      "offset": [0, 3, 0],
      "anchor": "top",
      "fontSize": 40,
      "color": "#ffffff",
      "backgroundColor": "rgba(155, 89, 182, 0.9)",
      "padding": 10,
      "visible": true
    },
    {
      "id": "light-velocity-vec",
      "type": "vector",
      "attachedToObjectId": "light_sphere",
      "vectorType": "velocity",
      "scale": 0.25,
      "color": "#DA70D6",
      "showMagnitude": false,
      "offset": [0, 0, 0],
      "anchor": "center",
      "visible": true,
      "shaftRadius": 0.04,
      "headLength": 0.2,
      "headRadius": 0.08
    },
    {
      "id": "light-mass",
      "type": "text",
      "attachedToObjectId": "light_sphere",
      "contentType": "mass",
      "prefix": "m = ",
      "suffix": " kg",
      "precision": 2,
      "offset": [0, -2.5, 0],
      "anchor": "bottom",
      "fontSize": 34,
      "color": "#DDA0DD",
      "backgroundColor": "rgba(0, 0, 0, 0.6)",
      "padding": 10,
      "visible": true
    }
  ],
  "controllers": [
    {
      "id": "proj_vx",
      "label": "Projectile Velocity X",
      "type": "slider",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "value": 10,
      "objectId": "projectile",
      "property": "velocity[0]"
    },
    {
      "id": "proj_vy",
      "label": "Projectile Velocity Y",
      "type": "slider",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "value": 6,
      "objectId": "projectile",
      "property": "velocity[1]"
    },
    {
      "id": "proj_mass",
      "label": "Projectile Mass",
      "type": "slider",
      "min": 0.5,
      "max": 5,
      "step": 0.1,
      "value": 2,
      "objectId": "projectile",
      "property": "mass"
    },
    {
      "id": "box_mass",
      "label": "Box Mass",
      "type": "slider",
      "min": 1,
      "max": 10,
      "step": 0.5,
      "value": 5,
      "objectId": "heavy_box",
      "property": "mass"
    },
    {
      "id": "gravity",
      "label": "Gravity",
      "type": "slider",
      "min": -20,
      "max": -1,
      "step": 0.5,
      "value": -9.81,
      "propertyPath": "gravity[1]"
    },
    {
      "id": "restitution",
      "label": "Bounciness",
      "type": "slider",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "value": 0.6,
      "propertyPath": "contactMaterial.restitution"
    }
  ]
}
