  "jsLoop": {
    "enabled": true,
    "tickHz": 2,
    "timeoutMs": 200,
    "code": "function jsLoop(ctx, state) { if (state && state.done) return { state: state }; var add = []; for (var i = 10; i < 100; i++) { var x = i % 10; var z = Math.floor(i / 10); add.push({ id: 'tile_' + i, type: 'Box', position: [x + 0.5, 0.5, z + 0.5], dimensions: [1, 1, 1], mass: 0, isStatic: true, color: '#3aa655' }); } return { state: { done: true }, addObjects: add }; }"
