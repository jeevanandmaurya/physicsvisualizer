  "jsLoop": {
    "enabled": true,
    "debug": false,
    "tickHz": 6,
    "timeoutMs": 200,
    "code": "function jsLoop(ctx,state){state=state||{};var pos=(ctx&&ctx.player&&ctx.player.position)||[0,0,0];var px=pos[0]||0;var pz=pos[2]||0;var chunkSize=12;var view=1;var maxChunksPerTick=1;var maxBlocksPerTick=60;var loaded=state.loaded;if(!loaded||typeof loaded!=='object'||Array.isArray(loaded)) loaded={};var queue=state.queue;if(!Array.isArray(queue)) queue=[];function hash2(x,z){var n=(x*374761393+z*668265263)|0;n=(n^(n>>13))|0;n=Math.imul(n,1274126177)|0;n=(n^(n>>16))|0;return (n>>>0)/4294967296;}function pushBlock(id,x,y,z,color){queue.push({id:id,type:'Box',position:[x+0.5,y+0.5,z+0.5],dimensions:[1,1,1],mass:0,isStatic:true,color:color,friction:0.9,restitution:0.03});}function enqueueChunk(cx,cz){var k=cx+','+cz;if(loaded[k]) return;loaded[k]=1;var baseX=cx*chunkSize;var baseZ=cz*chunkSize;var treeChance=hash2(cx,cz);var treeLX=Math.floor(hash2(cx*31,cz*17)*chunkSize);var treeLZ=Math.floor(hash2(cx*19,cz*29)*chunkSize);for(var x=0;x<chunkSize;x++){for(var z=0;z<chunkSize;z++){var wx=baseX+x;var wz=baseZ+z;var h=Math.floor(hash2(wx,wz)*2);for(var y=0;y<=h;y++){var top=(y===h);var color=top?'#3aa655':'#8b5a2b';var id='mc_'+cx+'_'+cz+'_'+x+'_'+y+'_'+z;pushBlock(id,wx,y,wz,color);}}}if(treeChance<0.22){var tx=baseX+treeLX;var tz=baseZ+treeLZ;var th=Math.floor(hash2(tx,tz)*2);for(var ty=th+1;ty<=th+4;ty++){pushBlock('mc_tree_log_'+cx+'_'+cz+'_'+ty,tx,ty,tz,'#a67c52');}var leafY=th+5;for(var lx=-1;lx<=1;lx++){for(var lz=-1;lz<=1;lz++){pushBlock('mc_tree_leaf_'+cx+'_'+cz+'_'+lx+'_'+lz,tx+lx,leafY,tz+lz,'#2e8b57');pushBlock('mc_tree_leaf2_'+cx+'_'+cz+'_'+lx+'_'+lz,tx+lx,leafY+1,tz+lz,'#2e8b57');}}}}var bx=Math.floor(px);var bz=Math.floor(pz);var ccx=Math.floor(bx/chunkSize);var ccz=Math.floor(bz/chunkSize);var queued=0;for(var dx=-view;dx<=view;dx++){for(var dz=-view;dz<=view;dz++){if(queued>=maxChunksPerTick) break;var cx=ccx+dx;var cz=ccz+dz;var key=cx+','+cz;if(!loaded[key]){enqueueChunk(cx,cz);queued++;}}if(queued>=maxChunksPerTick) break;}var add=[];for(var i=0;i<maxBlocksPerTick && queue.length>0;i++){add.push(queue.shift());}state.loaded=loaded;state.queue=queue;return add.length?{state:state,addObjects:add}:{state:state};}"
  }
